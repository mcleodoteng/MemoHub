{
  "name": "backend",
  "version": "1.0.0",
  "description": "MemoHub Backend API",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/server.js",
    "start:prod": "node dist/server.js",
    "dev": "nodemon --watch src --watch prisma --ext ts,json,prisma --ignore dist --exec \"npm run build && node dist/server.js\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "cleanup:group-conversations": "node scripts/cleanup-group-conversations.mjs",
    "cleanup:group-conversations:dry": "node scripts/cleanup-group-conversations.mjs --dry-run",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "memohub",
    "api",
    "express",
    "typescript"
  ],
  "author": "Mcleod Oteng",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.0",
    "nodemailer": "^8.0.2",
    "prisma": "^5.14.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.3"
  }
}
