# Environment Variables
NODE_ENV=development
PORT=5000
LOG_REQUESTS=true
JWT_SECRET=change-this-jwt-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_EXPIRES_IN=7d
DATABASE_URL=mysql://user:password@localhost:3306/memohub
FRONTEND_URL=http://localhost:8080
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
UPLOAD_MAX_SIZE=10485760
CORS_ORIGIN=http://localhost:8080,http://localhost:3000
STORAGE_TYPE=local
UPLOAD_DIR=uploads

# Mailtrap Email Sending API (real inbox delivery)
# Leave blank when using SMTP only. For Mailtrap Sending, use the API token
# from Email Sending, not your sandbox password.
MAILTRAP_API_TOKEN=
MAILTRAP_API_URL=https://send.api.mailtrap.io/api/send
FROM_NAME=MemoHub
# For real inbox delivery, set this to a verified sender/domain from Mailtrap.
FROM_EMAIL=hello@demomailtrap.co

# SMTP configuration
# Sandbox testing inbox: sandbox.smtp.mailtrap.io
# Real inbox delivery: live.smtp.mailtrap.io with Mailtrap Sending credentials
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=